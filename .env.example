# Configuracion web de Firebase (Project Settings > General > Tus apps > SDK setup).
# Son publicas por diseno (van al bundle del cliente) - la seguridad real vive en
# firestore.rules / storage.rules, no en ocultar estos valores.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Credenciales del SDK de administrador. Solo se usan en route handlers
# (app/api/**) via firebase/admin.ts - nunca van al cliente.
#
# Opcion A - clave de Service Account (Project Settings > Service accounts >
# Generate new private key). Requiere que la organizacion permita crear claves.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
#
# Opcion B - sin clave (Application Default Credentials). Deja las 3 variables
# de arriba vacias y en su lugar:
#   - Local: corre `gcloud auth application-default login` una vez: el SDK
#     detecta esas credenciales automaticamente, no se necesita variable.
#   - Produccion (Vercel u otro entorno fuera de GCP): usa Workload Identity
#     Federation y define GOOGLE_APPLICATION_CREDENTIALS apuntando al JSON de
#     configuracion (sin secretos) que genera ese flujo. Ver GUIA-DEPLOY.md.

# API key de OpenAI (platform.openai.com), usada solo en
# app/api/ai/generate-design/route.ts para la generacion de diseno con IA
# (features/ai-design). Nunca se expone al cliente.
OPENAI_API_KEY=
